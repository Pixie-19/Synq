rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. USERS COLLECTION
    match /users/{userId} {
      // Allow any authenticated user to read/list profiles for the Discovery feed
      allow read: if isAuthenticated();
      
      // Users can only create or edit their own profiles
      allow create, update: if isOwner(userId);
      allow delete: if false; // Soft deletes preferred
      
      // 2. SWIPES SUBCOLLECTION
      match /swipes/{targetId} {
        // Users can only see and add to their own swipe history
        allow read, write: if isOwner(userId);
      }
    }

    // 3. MATCHES COLLECTION
    match /matches/{matchId} {
      // For list queries (where('users', 'array-contains', uid)), we must check resource.data.users
      // For get doc (which might not exist yet), we fallback to regex matchId validation
      allow read: if isAuthenticated() && (
        (resource != null && request.auth.uid in resource.data.users) || 
        matchId.matches('.*' + request.auth.uid + '.*')
      );
      allow create: if isAuthenticated() && (request.auth.uid in request.resource.data.users);
      allow update, delete: if isAuthenticated() && matchId.matches('.*' + request.auth.uid + '.*');

      // 4. MESSAGES SUBCOLLECTION
      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && matchId.matches('.*' + request.auth.uid + '.*');
      }
    }

    // 5. VOICE ROOMS COLLECTION
    match /voiceRooms/{matchId} {
      // Direct string matching prevents missing document errors (get() failures)
      allow read, write: if isAuthenticated() && matchId.matches('.*' + request.auth.uid + '.*');
    }
  }
}
