rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is operating on their own document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // User profiles
    match /users/{userId} {
      allow read, list: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      
      // Swipes subcollection
      match /swipes/{targetId} {
        allow read, list: if isOwner(userId);
        allow create, update: if isOwner(userId);
      }
    }

    // Matches
    match /matches/{matchId} {
      allow read, list: if isAuthenticated() && (request.auth.uid in resource.data.users);
      allow create: if isAuthenticated() && (request.auth.uid in request.resource.data.users);
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.users);
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.users);
        allow create: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.users);
      }
    }

    // Voice Rooms
    match /voiceRooms/{matchId} {
      allow read, write: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.users);
    }
  }
}
