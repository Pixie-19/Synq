{
  "expo": {
    "name": "Synq",
    "slug": "Synq",
    "scheme": "synq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.synq.hackathon"
    },
    "android": {
      "package": "com.synq.hackathon",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Synq needs photo library access so you can update your profile image.",
          "cameraPermission": "Synq needs camera access so you can take a new profile photo."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "97e15b53-7044-444c-982d-111a3fe485fd"
      }
    }
  }
}
